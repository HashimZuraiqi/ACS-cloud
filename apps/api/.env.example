# apps/api/.env
PORT=3000

# Backend Services AWS Credentials (Required for DynamoDB & Amazon Bedrock AI)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_backend_access_key_here
AWS_SECRET_ACCESS_KEY=your_backend_secret_key_here

# JWT Secret for Authenticating User Sessions (Replace with a secure random string)
JWT_SECRET=super_secret_string_here
